# GEMINI_API_KEY: Required for Gemini AI API calls.
# jcruspero3263 automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the jcruspero3263 UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# jcruspero3263 automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

